; --- CÓDIGO GENERADO — no editar, se regenera al guardar ---
either empty? system/options/args [
    view layout [
        text "Iteración:"
        lbl-iter: text "0" 120x24
        button "Run" [
            _while-loop_1_i: 0
            until [
                const_1_result: 100000.0
                gt-op_1_result: _while-loop_1_i > const_1_result
                _while-loop_1_i: _while-loop_1_i + 1
                lbl-iter/text: form _while-loop_1_i
                do-events/no-wait
                gt-op_1_result
            ]
            lbl-iter/text: "¡Listo!"
        ]
    ]
][
    _while-loop_1_i: 0 until [const_1_result: 100000.0 gt-op_1_result: _while-loop_1_i > const_1_result _while-loop_1_i: _while-loop_1_i + 1 do-events/no-wait gt-op_1_result]
]
